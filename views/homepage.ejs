<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ShopZone — Premium eCommerce</title>
  <meta name="description" content="Shop the best products across Electronics, Clothing, Books, Sports and more.">
</head>
<body>

<%- include('./partials/navbar') %>

<style>
  /* ── Homepage-specific styles ─────────────────────────── */
  .hero-cinematic {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
  }
  .hero-cinematic-bg {
    position: absolute; inset: 0;
    background-image: url('/uploads/hero_background.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
    transform: scale(1.05);
    transition: transform 8s ease;
  }
  .hero-cinematic-bg.loaded { transform: scale(1); }
  .hero-cinematic-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(5,5,5,0.55) 0%,
      rgba(5,5,5,0.45) 40%,
      rgba(5,5,5,0.75) 100%
    );
    z-index: 1;
  }
  .hero-cinematic-content {
    position: relative; z-index: 2;
    max-width: 860px;
    padding: 0 24px;
  }
  .hero-cinematic-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin-bottom: 20px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .hero-cinematic-desc {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255,255,255,0.82);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 40px;
  }
  .hero-cinematic-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-hero-primary {
    background: var(--color-primary, #e11d48);
    color: white;
    padding: 16px 40px;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-hero-primary:hover { background: #be123c; transform: translateY(-2px); }
  .btn-hero-outline {
    background: transparent;
    color: white;
    padding: 16px 40px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.5);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .btn-hero-outline:hover { background: rgba(255,255,255,0.1); border-color: white; }

  /* Stats bar */
  .stats-bar {
    background: #0d0d0d;
    border-top: 1px solid #1a1a1a;
    padding: 40px 0;
  }
  .stats-bar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    max-width: 900px;
    margin: 0 auto;
  }
  .stats-bar-item {
    text-align: left;
    padding: 0 40px;
    border-right: 1px solid #222;
  }
  .stats-bar-item:first-child { padding-left: 0; }
  .stats-bar-item:last-child { border-right: none; }
  .stats-bar-value {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1;
    display: block;
    margin-bottom: 6px;
  }
  .stats-bar-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #666;
  }

  /* Category cards */
  .cat-hover-group:hover .cat-underline { transform: scaleX(1); }
  .cat-hover-group:hover .cat-bg-img { transform: scale(1.08); }
  .cat-underline { transition: transform 0.3s ease; transform: scaleX(0); transform-origin: left; height: 2px; background: var(--color-primary,#e11d48); margin-top: 6px; display: block; width: 100%; }

  /* Product card improvements */
  .product-card-v2 {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .product-card-v2:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(0,0,0,0.12); }
  .product-card-v2-image {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f5f5f5;
  }
  .product-card-v2-image img,
  .product-card-v2-image .cat-img-fallback {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }
  .product-card-v2:hover .product-card-v2-image img,
  .product-card-v2:hover .cat-img-fallback { transform: scale(1.06); }
  .cat-img-fallback {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    color: white; text-align: center; padding: 16px;
  }
  .product-card-v2-body { padding: 16px; display: flex; flex-direction: column; flex: 1; }
  .product-card-v2-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.5);
    opacity: 0; transition: opacity 0.3s;
    display: flex; align-items: center; justify-content: center; gap: 12px;
    z-index: 3;
  }
  .product-card-v2:hover .product-card-v2-overlay { opacity: 1; }

  /* Trust cards */
  .trust-card-v2 { transition: transform 0.3s, border-top-color 0.3s, box-shadow 0.3s; }
  .trust-card-v2:hover { transform: translateY(-5px); border-top-color: var(--color-primary,#e11d48) !important; box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important; }

  /* Responsive */
  @media(max-width: 900px) {
    .stats-bar-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-bar-item { border-right: none; border-bottom: 1px solid #222; padding: 16px 0; }
    .stats-bar-item:last-child, .stats-bar-item:nth-child(2) { border-bottom: none; }
    .cat-grid-custom { grid-template-columns: repeat(2,1fr) !important; }
    .trust-grid { grid-template-columns: repeat(2,1fr) !important; }
    .promo-grid { grid-template-columns: 1fr !important; }
  }
  @media(max-width: 576px) {
    .cat-grid-custom { grid-template-columns: 1fr !important; }
    .trust-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ═══ HERO ═══════════════════════════════════════════════════ -->
<section class="hero-cinematic">
  <div class="hero-cinematic-bg" id="heroBg"></div>
  <div class="hero-cinematic-overlay"></div>
  <div class="hero-cinematic-content animate-fade-in-up" style="padding-top: calc(var(--navbar-height, 72px) + 60px); padding-bottom: 80px;">
    <p style="font-size:0.75rem; font-weight:700; letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.5); margin-bottom:20px;">New Season Collection</p>
    <h1 class="hero-cinematic-title">
      Discover Products You'll Absolutely Love
    </h1>
    <div style="width:60px; height:2px; background:#e63946; margin:24px auto 24px; border-radius:2px;"></div>
    <p class="hero-cinematic-desc">
      Explore thousands of premium products across every category. Unbeatable prices, fast delivery, and a shopping experience unlike any other.
    </p>
    <div class="hero-cinematic-actions">
      <a href="/products" class="btn-hero-primary">SHOP NOW &nbsp;→</a>
      <a href="/products?featured=true" class="btn-hero-outline">FEATURED PRODUCTS</a>
    </div>
  </div>
</section>


<!-- ═══ STATS BAR ══════════════════════════════════════════════ -->
<div class="stats-bar">
  <div class="stats-bar-grid" style="padding: 0 24px; box-sizing: content-box;">
    <div class="stats-bar-item">
      <span class="stats-bar-value">40+</span>
      <span class="stats-bar-label">Products</span>
    </div>
    <div class="stats-bar-item">
      <span class="stats-bar-value">8</span>
      <span class="stats-bar-label">Categories</span>
    </div>
    <div class="stats-bar-item">
      <span class="stats-bar-value">24h</span>
      <span class="stats-bar-label">Fast Delivery</span>
    </div>
    <div class="stats-bar-item">
      <span class="stats-bar-value">100%</span>
      <span class="stats-bar-label">Secure</span>
    </div>
  </div>
</div>

<!-- ═══ CATEGORIES ══════════════════════════════════════════════ -->
<section class="section" style="background:var(--color-gray-50)">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">Browse By Category</span>
      <h2 class="section-title">Shop Every Department</h2>
      <p class="section-subtitle">From cutting-edge electronics to everyday essentials — find everything in one place.</p>
    </div>

    <div class="cat-grid-custom" style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px; margin-top:32px;">
      <%
        const cats = [
          { name:'Electronics',   img:'/uploads/electronics.jpg',       slug:'Electronics' },
          { name:'Clothing',      img:'/uploads/clothing.jpg',          slug:'Clothing' },
          { name:'Books',         img:'/uploads/books.jpg',             slug:'Books' },
          { name:'Home & Kitchen',img:'/uploads/home and kitchen.jpg',  slug:'Home & Kitchen' },
          { name:'Sports',        img:'/uploads/sports.jpg',            slug:'Sports' },
          { name:'Beauty',        img:'/uploads/beauty.jpg',            slug:'Beauty' },
          { name:'Toys',          img:'/uploads/toys.jpg',              slug:'Toys' },
          { name:'Automotive',    img:'/uploads/automotive.jpg',        slug:'Automotive' }
        ];
      %>
      <% cats.forEach((cat, idx) => { %>
      <a href="/products?category=<%= encodeURIComponent(cat.slug) %>"
         class="reveal stagger-<%= (idx % 8) + 1 %> cat-hover-group"
         style="display:flex; flex-direction:column; justify-content:flex-end; align-items:flex-start; aspect-ratio:4/3; border-radius:16px; text-decoration:none; color:white; position:relative; overflow:hidden; padding:20px;">
        <img src="<%= cat.img %>" alt="<%= cat.name %>" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover; z-index:0; transition:transform 0.5s ease;" class="cat-bg-img">
        <div style="position:absolute; top:0; left:0; width:100%; height:100%; background:linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.15) 55%, rgba(0,0,0,0) 100%); z-index:1;"></div>
        <div style="width:100%; text-align:left; z-index:2; position:relative;">
          <span style="font-weight:700; font-size:1.1rem; letter-spacing:0.5px; text-shadow:0 2px 6px rgba(0,0,0,0.6);"><%= cat.name %></span>
          <span class="cat-underline"></span>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- ═══ FEATURED PRODUCTS ═══════════════════════════════════════ -->
<% if (featuredProducts && featuredProducts.length) { %>
<section class="section">
  <div class="container">
    <div class="section-header-row reveal">
      <div>
        <span class="section-eyebrow">Hand-Picked</span>
        <h2 class="section-title" style="margin-bottom:0">Featured Products</h2>
      </div>
      <a href="/products?featured=true" class="btn btn-secondary">View All →</a>
    </div>

    <div class="product-grid">
      <% featuredProducts.forEach((p, idx) => {
           const hasDiscount = p.isOnSale && p.discountPercent > 0;
           const salePrice   = hasDiscount ? Math.round(p.price * (1 - p.discountPercent/100)) : p.price;
           const stars       = '★'.repeat(Math.round(p.rating||4)) + '☆'.repeat(5-Math.round(p.rating||4));
           const stockClass  = p.stock === 0 ? 'stock-out' : p.stock < 5 ? 'stock-low' : 'stock-in';
           const stockText   = p.stock === 0 ? 'Out of Stock' : p.stock < 5 ? `Only ${p.stock} left` : 'In Stock';
           const catImages = {
             'Electronics': '/uploads/electronics.jpg',
             'Clothing': '/uploads/clothing.jpg',
             'Books': '/uploads/books.jpg',
             'Home & Kitchen': '/uploads/home and kitchen.jpg',
             'Sports': '/uploads/sports.jpg',
             'Beauty': '/uploads/beauty.jpg',
             'Toys': '/uploads/toys.jpg',
             'Automotive': '/uploads/automotive.jpg'
           };
           const catColors = {
             'Electronics':'linear-gradient(135deg,#3b82f6,#1d4ed8)',
             'Clothing':'linear-gradient(135deg,#a855f7,#7e22ce)',
             'Books':'linear-gradient(135deg,#14b8a6,#0f766e)',
             'Home & Kitchen':'linear-gradient(135deg,#ef4444,#b91c1c)',
             'Sports':'linear-gradient(135deg,#1e3a8a,#172554)',
             'Beauty':'linear-gradient(135deg,#f43f5e,#be123c)',
             'Toys':'linear-gradient(135deg,#22c55e,#15803d)',
             'Automotive':'linear-gradient(135deg,#4b5563,#374151)'
           };
           const catEmojis = {
             'Electronics':'💻','Clothing':'👗','Books':'📚','Home & Kitchen':'🏠',
             'Sports':'⚽','Beauty':'💄','Toys':'🧸','Automotive':'🚗'
           };
           const fallbackImg  = catImages[p.category];
           const fallbackBg   = catColors[p.category] || 'linear-gradient(135deg,#6b7280,#374151)';
           const fallbackEmoji = catEmojis[p.category] || '📦';
      %>
      <div class="product-card-v2 reveal stagger-<%= (idx % 8) + 1 %>">
        <div class="product-card-v2-image">
          <% if (p.image) { %>
            <img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy">
          <% } else if (fallbackImg) { %>
            <img src="<%= fallbackImg %>" alt="<%= p.name %>" loading="lazy" class="cat-img-fallback" style="display:block">
          <% } else { %>
            <div class="cat-img-fallback" style="background:<%= fallbackBg %>; width:100%; height:100%;">
              <span style="font-size:3rem; margin-bottom:8px;"><%= fallbackEmoji %></span>
              <span style="font-weight:700; font-size:0.95rem; text-shadow:0 2px 4px rgba(0,0,0,0.4);"><%= p.name %></span>
            </div>
          <% } %>

          <!-- Badges -->
          <div class="card-badges">
            <% if (p.featured) { %><span class="badge badge-featured">⭐ Featured</span><% } %>
            <% if (hasDiscount) { %><span class="badge badge-sale">-<%= p.discountPercent %>%</span><% } %>
            <% if (p.stock === 0) { %><span class="badge badge-out-of-stock">Sold Out</span><% } %>
          </div>

          <!-- Overlay actions (preserved exactly) -->
          <div class="product-card-v2-overlay card-actions-overlay">
            <a href="/products/<%= p._id %>" class="card-quick-btn">👁 View</a>
            <% if (p.stock > 0) { %>
            <button class="card-quick-btn primary"
              data-add-to-cart
              data-id="<%= p._id %>"
              data-name="<%= p.name %>"
              data-price="<%= salePrice %>"
              data-image="<%= p.image || '' %>"
              data-brand="<%= p.brand || '' %>"
              data-category="<%= p.category %>">
              ⚡ Quick Add
            </button>
            <% } %>
          </div>
        </div>

        <div class="product-card-v2-body">
          <span class="product-card-category"><%= p.category %></span>
          <div class="product-card-name"><%= p.name %></div>
          <% if (p.brand) { %><div class="product-card-brand"><%= p.brand %></div><% } %>
          <div class="product-card-rating">
            <span class="stars"><%= stars %></span>
            <span class="stars-count">(<%= p.rating || 4 %>)</span>
          </div>
          <div class="product-card-price">
            <span class="price-current">PKR <%= salePrice.toLocaleString() %></span>
            <% if (hasDiscount) { %>
              <span class="price-original">PKR <%= p.price.toLocaleString() %></span>
              <span class="price-discount">-<%= p.discountPercent %>%</span>
            <% } %>
          </div>
          <div class="stock-indicator <%= stockClass %>" style="margin-bottom:16px;">● <%= stockText %></div>

          <div style="margin-top:auto;">
            <% if (p.stock > 0) { %>
            <button style="width:100%; background:var(--color-primary); color:white; border:none; padding:12px; border-radius:8px; font-weight:600; cursor:pointer; display:flex; justify-content:center; align-items:center; gap:8px; transition:background 0.2s;"
              onmouseover="this.style.background='var(--color-primary-hover)'"
              onmouseout="this.style.background='var(--color-primary)'"
              data-add-to-cart
              data-id="<%= p._id %>"
              data-name="<%= p.name %>"
              data-price="<%= salePrice %>"
              data-image="<%= p.image || '' %>"
              data-brand="<%= p.brand || '' %>"
              data-category="<%= p.category %>">
              🛒 Add to Cart
            </button>
            <% } else { %>
            <button style="width:100%; background:var(--color-gray-200); color:var(--color-gray-500); border:none; padding:12px; border-radius:8px; font-weight:600; cursor:not-allowed;" disabled>
              Out of Stock
            </button>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- ═══ PROMO BANNER ════════════════════════════════════════════ -->
<section class="section-sm">
  <div class="container">
    <div class="promo-banner reveal promo-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:40px; background:linear-gradient(135deg, var(--color-primary), #1a0a0f); border-radius:24px; padding:48px; color:white; align-items:center; position:relative; overflow:hidden;">
      <!-- Left side -->
      <div style="position:relative; z-index:2;">
        <div style="font-weight:600; letter-spacing:1px; text-transform:uppercase; margin-bottom:12px; color:rgba(255,255,255,0.7); font-size:0.8rem;">Limited Time Offer</div>
        <h2 style="font-size:2.5rem; font-weight:800; line-height:1.2; margin-bottom:16px; color:white;">
          Get Up To <span style="color:#fcd34d;">20% Off</span><br>Your First Order
        </h2>
        <p style="font-size:1.05rem; line-height:1.6; margin-bottom:32px; color:rgba(255,255,255,0.85);">
          Use code <strong style="color:white; background:rgba(255,255,255,0.15); padding:4px 10px; border-radius:6px;">SHOPZONE20</strong> at checkout. Valid on all products, no minimum order required.
        </p>
        <div style="display:flex; gap:16px; flex-wrap:wrap;">
          <a href="/products" style="background:white; color:var(--color-primary); font-weight:700; padding:14px 28px; border-radius:4px; text-decoration:none; font-size:0.9rem; letter-spacing:1px; text-transform:uppercase;">Shop Now</a>
          <a href="/register" style="background:rgba(255,255,255,0.08); color:white; border:1px solid rgba(255,255,255,0.3); font-weight:600; padding:14px 28px; border-radius:4px; text-decoration:none; font-size:0.9rem; letter-spacing:1px; text-transform:uppercase;">Join Free</a>
        </div>
      </div>
      <!-- Right stat cards -->
      <div style="position:relative; z-index:2; display:flex; flex-direction:column; gap:16px;">
        <div style="background:rgba(255,255,255,0.07); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.12); padding:20px; border-radius:16px; display:flex; align-items:center; gap:16px;">
          <div style="font-size:2rem; background:rgba(255,255,255,0.12); width:52px; height:52px; display:flex; align-items:center; justify-content:center; border-radius:12px; flex-shrink:0;">💸</div>
          <div><div style="font-weight:700; font-size:1.15rem;">20% OFF</div><div style="font-size:0.88rem; color:rgba(255,255,255,0.7);">On your first purchase</div></div>
        </div>
        <div style="background:rgba(255,255,255,0.07); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.12); padding:20px; border-radius:16px; display:flex; align-items:center; gap:16px;">
          <div style="font-size:2rem; background:rgba(255,255,255,0.12); width:52px; height:52px; display:flex; align-items:center; justify-content:center; border-radius:12px; flex-shrink:0;">🚚</div>
          <div><div style="font-weight:700; font-size:1.15rem;">Free Shipping</div><div style="font-size:0.88rem; color:rgba(255,255,255,0.7);">Orders over PKR 5,000</div></div>
        </div>
        <div style="background:rgba(255,255,255,0.07); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.12); padding:20px; border-radius:16px; display:flex; align-items:center; gap:16px;">
          <div style="font-size:2rem; background:rgba(255,255,255,0.12); width:52px; height:52px; display:flex; align-items:center; justify-content:center; border-radius:12px; flex-shrink:0;">⚡</div>
          <div><div style="font-weight:700; font-size:1.15rem;">24h Delivery</div><div style="font-size:0.88rem; color:rgba(255,255,255,0.7);">Fast &amp; reliable</div></div>
        </div>
      </div>
      <!-- Decoration blob -->
      <div style="position:absolute; top:-40%; right:-10%; width:400px; height:400px; background:rgba(255,255,255,0.04); border-radius:50%; filter:blur(80px); z-index:1;"></div>
    </div>
  </div>
</section>

<!-- ═══ TRUST FEATURES ══════════════════════════════════════════ -->
<section class="section-sm" style="background:var(--color-gray-50)">
  <div class="container">
    <div class="trust-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:24px;">
      <% [
        { icon:'🚚', title:'Free Shipping',  desc:'On orders over PKR 5,000', color:'#3b82f6' },
        { icon:'↩',  title:'Easy Returns',   desc:'30-day hassle-free policy', color:'#10b981' },
        { icon:'🔒', title:'Secure Payment', desc:'256-bit SSL encryption',    color:'#f59e0b' },
        { icon:'🎧', title:'24/7 Support',   desc:'Always here to help you',   color:'#8b5cf6' }
      ].forEach(f => { %>
      <div class="reveal trust-card-v2" style="text-align:center; padding:32px 16px; background:white; border-radius:16px; box-shadow:0 4px 6px rgba(0,0,0,0.05); border-top:4px solid transparent;">
        <div style="width:64px; height:64px; border-radius:50%; background:<%= f.color %>18; display:flex; align-items:center; justify-content:center; font-size:2rem; margin:0 auto 16px auto;"><%= f.icon %></div>
        <div style="font-weight:700; font-size:1.05rem; color:var(--color-gray-900); margin-bottom:6px;"><%= f.title %></div>
        <div style="font-size:0.88rem; color:var(--color-gray-500);"><%= f.desc %></div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('./partials/footer') %>

<button class="scroll-top" aria-label="Back to top">↑</button>
<script src="/js/cart.js"></script>
<script>
  // Subtle ken-burns effect on hero bg
  document.addEventListener('DOMContentLoaded', function() {
    var bg = document.getElementById('heroBg');
    if (bg) setTimeout(function(){ bg.classList.add('loaded'); }, 100);
  });
</script>
</body>
</html>
