<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Products — ShopZone Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/flash') %>
<script src="/js/main.js"></script>

<div class="admin-layout">
  <%- include('../partials/adminSidebar', { activePage: 'products' }) %>

  <div class="admin-main">
    <div class="admin-topbar">
      <div class="admin-topbar-title">Products <span>/ Manage Catalogue</span></div>
      <div class="admin-topbar-right">
        <a href="/admin/products/add" class="btn btn-primary btn-sm">+ Add Product</a>
        <div class="admin-user-pill">
          <div class="avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
          <%= currentUser.name.split(' ')[0] %>
        </div>
      </div>
    </div>

    <div class="admin-content">
      <div class="admin-table-wrap">
        <div class="admin-table-header">
          <div class="admin-table-title">All Products (<%= products.length %>)</div>
          <div style="display:flex;gap:10px;align-items:center">
            <input type="text" id="tableSearch" placeholder="Search products…"
              style="padding:8px 14px;border:1.5px solid var(--color-gray-200);border-radius:var(--border-radius-full);font-size:.85rem;outline:none;width:220px"
              oninput="filterTable(this.value)">
          </div>
        </div>

        <table class="data-table" id="productsTable">
          <thead>
            <tr>
              <th>Product</th>
              <th>Category</th>
              <th>Price</th>
              <th>Stock</th>
              <th>Featured</th>
              <th>Sale</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(p => {
                 const sp = p.isOnSale && p.discountPercent > 0
                   ? Math.round(p.price*(1-p.discountPercent/100)) : p.price;
            %>
            <tr>
              <td>
                <div class="product-thumb-cell">
                  <% if (p.image) { %>
                    <img src="<%= p.image %>" class="product-thumb" alt="">
                  <% } else { %>
                    <div class="product-thumb-placeholder">📦</div>
                  <% } %>
                  <div>
                    <div class="table-product-name"><%= p.name.slice(0,32) %><%= p.name.length>32?'…':'' %></div>
                    <div class="table-product-brand"><%= p.brand||'—' %></div>
                  </div>
                </div>
              </td>
              <td><span style="font-size:.8rem;background:var(--color-gray-100);padding:3px 10px;border-radius:var(--border-radius-full);font-weight:600"><%= p.category %></span></td>
              <td>
                <div style="font-weight:700;font-size:.9rem">PKR <%= sp.toLocaleString() %></div>
                <% if (p.isOnSale) { %><div style="font-size:.75rem;text-decoration:line-through;color:var(--color-gray-400)">PKR <%= p.price.toLocaleString() %></div><% } %>
              </td>
              <td>
                <% if (p.stock===0) { %>
                  <span class="stock-pill-out">0 — Out</span>
                <% } else if (p.stock<5) { %>
                  <span class="stock-pill-low"><%= p.stock %> — Low</span>
                <% } else { %>
                  <span class="stock-pill-in"><%= p.stock %></span>
                <% } %>
              </td>
              <td style="text-align:center"><%= p.featured ? '⭐' : '—' %></td>
              <td style="text-align:center">
                <% if (p.isOnSale) { %>
                  <span style="font-size:.75rem;font-weight:700;color:var(--color-accent)">-<%= p.discountPercent %>%</span>
                <% } else { %>—<% } %>
              </td>
              <td>
                <div class="table-actions">
                  <a href="/admin/products/edit/<%= p._id %>" class="action-btn action-btn-edit" title="Edit">✏</a>
                  <form action="/admin/products/delete/<%= p._id %>" method="POST" style="display:inline"
                        onsubmit="return confirm('Delete <%= p.name.replace(/'/g,"\\'") %>?')">
                    <button type="submit" class="action-btn action-btn-delete" title="Delete">🗑</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
function filterTable(q) {
  const rows = document.querySelectorAll('#productsTable tbody tr');
  q = q.toLowerCase();
  rows.forEach(r => {
    r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}
</script>
</body>
</html>
