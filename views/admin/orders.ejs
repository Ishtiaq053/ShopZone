<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orders — ShopZone Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/flash') %>
<script src="/js/main.js"></script>

<div class="admin-layout">
  <%- include('../partials/adminSidebar', { activePage: 'orders' }) %>

  <div class="admin-main">
    <div class="admin-topbar">
      <div class="admin-topbar-title">Orders <span>/ All Orders</span></div>
      <div class="admin-topbar-right">
        <div class="admin-user-pill">
          <div class="avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
          <%= currentUser.name.split(' ')[0] %>
        </div>
      </div>
    </div>

    <div class="admin-content">
      <div class="admin-table-wrap">
        <div class="admin-table-header">
          <div class="admin-table-title">All Orders (<%= orders.length %>)</div>
        </div>

        <% if (orders.length === 0) { %>
          <div style="text-align:center;padding:48px;color:var(--color-gray-400)">
            <div style="font-size:3rem;margin-bottom:12px">🛒</div>
            <div style="font-size:1rem;font-weight:600">No orders yet</div>
            <div style="font-size:.85rem;margin-top:6px">Orders will appear here once customers checkout.</div>
          </div>
        <% } else { %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Customer</th>
              <th>Items</th>
              <th>Total</th>
              <th>Status</th>
              <th>Date</th>
              <th>Update Status</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(o => { %>
            <tr>
              <td style="font-size:.75rem;color:var(--color-gray-500);font-family:monospace">
                #<%= o._id.toString().slice(-8).toUpperCase() %>
              </td>
              <td>
                <div style="font-weight:600;font-size:.875rem"><%= o.user ? o.user.name : 'Deleted User' %></div>
                <div style="font-size:.75rem;color:var(--color-gray-400)"><%= o.user ? o.user.email : '—' %></div>
              </td>
              <td style="font-size:.875rem"><%= o.products.length %> item<%= o.products.length!==1?'s':'' %></td>
              <td style="font-weight:700;font-size:.9rem">PKR <%= o.totalAmount.toLocaleString() %></td>
              <td><span class="status-pill status-<%= o.status %>"><%= o.status %></span></td>
              <td style="font-size:.78rem;color:var(--color-gray-500)">
                <%= new Date(o.createdAt).toLocaleDateString('en-PK', {year:'numeric',month:'short',day:'numeric'}) %>
              </td>
              <td>
                <form action="/admin/orders/<%= o._id %>/status" method="POST"
                      style="display:flex;gap:8px;align-items:center">
                  <select name="status"
                    style="padding:6px 10px;border:1.5px solid var(--color-gray-200);border-radius:var(--border-radius-full);font-size:.78rem;outline:none;background:white;cursor:pointer">
                    <% ['pending','confirmed','shipped','delivered','cancelled'].forEach(s => { %>
                      <option value="<%= s %>" <%= o.status===s?'selected':'' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option>
                    <% }) %>
                  </select>
                  <button type="submit" class="btn btn-sm" style="padding:6px 12px;font-size:.78rem;background:var(--color-primary);color:white;border-color:var(--color-primary)">
                    Update
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</div>
</body>
</html>
