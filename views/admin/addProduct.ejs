<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Product — ShopZone Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/flash') %>
<script src="/js/main.js"></script>

<div class="admin-layout">
  <%- include('../partials/adminSidebar', { activePage: 'add' }) %>

  <div class="admin-main">
    <div class="admin-topbar">
      <div class="admin-topbar-title">Products <span>/ Add New Product</span></div>
      <div class="admin-topbar-right">
        <a href="/admin/products" class="btn btn-light btn-sm">← Back to Products</a>
        <div class="admin-user-pill">
          <div class="avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
          <%= currentUser.name.split(' ')[0] %>
        </div>
      </div>
    </div>

    <div class="admin-content">
      <form action="/admin/products/add" method="POST" enctype="multipart/form-data">
        <div class="admin-form-card">
          <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid var(--color-gray-200)">
            Product Information
          </h2>

          <div class="admin-form-grid">

            <!-- Name -->
            <div class="admin-form-full">
              <div class="form-group">
                <label class="form-label">Product Name *</label>
                <input type="text" name="name" class="form-control-admin <%= errors.name?'is-invalid':'' %>"
                       placeholder="e.g. Samsung Galaxy S24 Ultra" value="<%= old.name||'' %>" required>
                <% if (errors.name) { %><div class="form-error">⚠ <%= errors.name %></div><% } %>
              </div>
            </div>

            <!-- Category & Brand -->
            <div class="form-group">
              <label class="form-label">Category *</label>
              <select name="category" class="form-control-admin <%= errors.category?'is-invalid':'' %>" required>
                <option value="">Select Category</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat %>" <%= old.category===cat?'selected':'' %>><%= cat %></option>
                <% }) %>
              </select>
              <% if (errors.category) { %><div class="form-error">⚠ <%= errors.category %></div><% } %>
            </div>

            <div class="form-group">
              <label class="form-label">Brand</label>
              <input type="text" name="brand" class="form-control-admin"
                     placeholder="e.g. Samsung, Apple, Nike" value="<%= old.brand||'' %>">
            </div>

            <!-- Price & Stock -->
            <div class="form-group">
              <label class="form-label">Price (PKR) *</label>
              <input type="number" name="price" class="form-control-admin <%= errors.price?'is-invalid':'' %>"
                     placeholder="0" min="0" step="1" value="<%= old.price||'' %>" required>
              <% if (errors.price) { %><div class="form-error">⚠ <%= errors.price %></div><% } %>
            </div>

            <div class="form-group">
              <label class="form-label">Stock Quantity *</label>
              <input type="number" name="stock" class="form-control-admin <%= errors.stock?'is-invalid':'' %>"
                     placeholder="0" min="0" value="<%= old.stock||'' %>" required>
              <% if (errors.stock) { %><div class="form-error">⚠ <%= errors.stock %></div><% } %>
            </div>

            <!-- Rating -->
            <div class="form-group">
              <label class="form-label">Rating (1–5)</label>
              <input type="number" name="rating" class="form-control-admin"
                     placeholder="4" min="1" max="5" step="0.1" value="<%= old.rating||'4' %>">
            </div>

            <!-- Description -->
            <div class="admin-form-full">
              <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control-admin"
                          placeholder="Describe the product features, specs, and benefits…"
                          rows="4"><%= old.description||'' %></textarea>
              </div>
            </div>

            <!-- Image upload -->
            <div class="admin-form-full">
              <div class="form-group">
                <label class="form-label">Product Image</label>
                <div class="image-upload-area">
                  <input type="file" name="image" accept="image/jpeg,image/png,image/webp" id="imgInput"
                         onchange="previewImage(this)">
                  <div class="image-upload-icon">📷</div>
                  <div class="image-upload-text">Click to upload or drag & drop</div>
                  <div class="image-upload-hint">JPG, PNG, WebP — Max 5MB</div>
                </div>
                <div id="imgPreview" class="image-preview" style="display:none">
                  <img id="previewImg" src="" alt="Preview">
                </div>
              </div>
            </div>

            <!-- Toggles -->
            <div class="form-group">
              <label class="form-label">Featured Product</label>
              <div class="form-toggle-group">
                <label class="toggle-switch">
                  <input type="checkbox" name="featured" value="true" <%= old.featured==='true'?'checked':'' %>>
                  <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label">Show in Featured section on homepage</span>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">On Sale</label>
              <div class="form-toggle-group">
                <label class="toggle-switch">
                  <input type="checkbox" name="isOnSale" value="true" id="onSaleToggle"
                         <%= old.isOnSale==='true'?'checked':'' %> onchange="toggleDiscount(this)">
                  <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label">Mark this product as on sale</span>
              </div>
            </div>

            <!-- Discount % (hidden unless on sale) -->
            <div class="form-group" id="discountGroup" style="<%= old.isOnSale==='true'?'':'display:none' %>">
              <label class="form-label">Discount Percentage (%)</label>
              <input type="number" name="discountPercent" class="form-control-admin"
                     placeholder="e.g. 20" min="1" max="99" value="<%= old.discountPercent||'' %>">
            </div>

          </div><!-- /admin-form-grid -->

          <!-- Form actions -->
          <div style="display:flex;gap:12px;margin-top:28px;padding-top:24px;border-top:1px solid var(--color-gray-200)">
            <button type="submit" class="btn btn-primary">✓ Add Product</button>
            <a href="/admin/products" class="btn btn-light">Cancel</a>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function previewImage(input) {
  const preview = document.getElementById('imgPreview');
  const img = document.getElementById('previewImg');
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => { img.src = e.target.result; preview.style.display = 'block'; };
    reader.readAsDataURL(input.files[0]);
  }
}
function toggleDiscount(checkbox) {
  document.getElementById('discountGroup').style.display = checkbox.checked ? '' : 'none';
}

// convert checkbox to hidden field value for form-control-admin toggle
document.querySelector('input[name="featured"]').addEventListener('change', function() {
  // the checkbox value "true" is sent when checked
});
</script>
</body>
</html>
