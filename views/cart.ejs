<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shopping Cart — ShopZone</title>
</head>
<body>

<%- include('./partials/navbar') %>

<div class="page-wrap">
  <div class="page-hero">
    <div class="container">
      <div class="breadcrumb" style="margin-bottom:10px">
        <a href="/">Home</a><span class="breadcrumb-sep">/</span>
        <span>Shopping Cart</span>
      </div>
      <h1 class="page-hero-title">Shopping Cart</h1>
      <p style="color:var(--color-gray-500);margin-top:6px;font-size:.9rem" id="cart-item-count">0 items</p>
    </div>
  </div>

  <div class="container section-sm">
    <div class="cart-layout">

      <!-- ── Cart Items ──────────────────────────────────── -->
      <div>
        <div class="cart-table-wrap">
          <div class="cart-table-header">
            <span>Product</span>
            <span>Price</span>
            <span>Quantity</span>
            <span>Total</span>
            <span></span>
          </div>

          <!-- Rendered by cart.js -->
          <div id="cart-items-container"></div>

          <!-- Empty state -->
          <div id="cart-empty" class="cart-empty" style="display:none">
            <div class="cart-empty-icon">🛒</div>
            <div class="cart-empty-title">Your Cart is Empty</div>
            <div class="cart-empty-text">Looks like you haven't added anything yet. Start shopping!</div>
            <a href="/products" class="btn btn-primary">Browse Products</a>
          </div>
        </div>

        <!-- Actions row -->
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:16px;flex-wrap:wrap;gap:12px">
          <a href="/products" class="btn btn-light btn-sm">← Continue Shopping</a>
          <button onclick="if(confirm('Clear all items?')){localStorage.removeItem('shopzone_cart');location.reload();}"
                  class="btn btn-sm"
                  style="color:var(--color-accent);border-color:var(--color-accent);background:transparent">
            🗑 Clear Cart
          </button>
        </div>
      </div>

      <!-- ── Order Summary ───────────────────────────────── -->
      <div class="cart-summary">
        <div class="cart-summary-title">Order Summary</div>

        <div class="cart-summary-row">
          <span>Subtotal</span>
          <span id="cart-subtotal">PKR 0</span>
        </div>
        <div class="cart-summary-row">
          <span>Shipping</span>
          <span id="cart-shipping">PKR 299</span>
        </div>
        <div class="cart-summary-row">
          <span style="font-size:.8rem;color:var(--color-gray-400)">Free shipping on orders over PKR 5,000</span>
        </div>
        <div class="cart-summary-row total">
          <span>Total</span>
          <span id="cart-total">PKR 0</span>
        </div>

        <button id="cart-checkout-btn" class="btn btn-primary cart-checkout-btn" disabled>
          Proceed to Checkout →
        </button>

        <a href="/products" class="cart-continue-link">← Continue Shopping</a>

        <div class="cart-trust-badges">
          <div class="trust-badge">
            <span class="icon">🔒</span>
            <span class="text">Secure Checkout</span>
          </div>
          <div class="trust-badge">
            <span class="icon">🚚</span>
            <span class="text">Fast Delivery</span>
          </div>
          <div class="trust-badge">
            <span class="icon">↩</span>
            <span class="text">Easy Returns</span>
          </div>
          <div class="trust-badge">
            <span class="icon">💳</span>
            <span class="text">All Cards</span>
          </div>
        </div>

        <!-- Payment methods -->
        <div style="text-align:center;margin-top:16px;font-size:.75rem;color:var(--color-gray-400)">
          💳 Visa · Mastercard · JazzCash · EasyPaisa
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>
<button class="scroll-top" aria-label="Back to top">↑</button>
<script src="/js/cart.js"></script>
</body>
</html>
