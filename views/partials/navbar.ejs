<!-- ═══ ShopZone Navbar ═══ -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<nav class="navbar">
  <div class="container navbar-inner">

    <!-- Brand -->
    <a href="/" class="navbar-brand">
      <div class="brand-icon">S</div>
      <span class="brand-text">Shop<span>Zone</span></span>
    </a>

    <!-- Search -->
    <div class="navbar-search">
      <form action="/products" method="GET">
        <input type="text" name="search" placeholder="Search products, brands…"
               value="<%= typeof search !== 'undefined' ? search : '' %>">
        <button type="submit">🔍</button>
      </form>
    </div>

    <!-- Desktop Nav -->
    <div class="navbar-nav">
      <a href="/products" class="nav-link">Products</a>

      <% if (currentUser) { %>
        <!-- Cart -->
        <a href="/cart" class="nav-link cart-icon-wrap">
          🛒
          <span class="cart-badge" style="display:none">0</span>
        </a>

        <% if (currentUser.role === 'admin') { %>
          <a href="/admin" class="nav-link">⚙ Admin</a>
        <% } %>

        <!-- User dropdown (simple) -->
        <span class="nav-link" style="color:var(--color-gray-600);font-size:.85rem">
          👤 <%= currentUser.name.split(' ')[0] %>
        </span>
        <a href="/logout" class="nav-link btn-primary-nav">Logout</a>

      <% } else { %>
        <a href="/cart" class="nav-link cart-icon-wrap">
          🛒
          <span class="cart-badge" style="display:none">0</span>
        </a>
        <a href="/login"    class="nav-link">Login</a>
        <a href="/register" class="nav-link btn-primary-nav">Register</a>
      <% } %>
    </div>

    <!-- Mobile toggle -->
    <button class="navbar-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile drawer -->
<div class="navbar-drawer">
  <div class="navbar-drawer-inner">
    <!-- mobile search -->
    <form action="/products" method="GET" style="margin-bottom:8px">
      <div style="display:flex;gap:8px">
        <input type="text" name="search" placeholder="Search…"
               value="<%= typeof search !== 'undefined' ? search : '' %>"
               style="flex:1;padding:10px 14px;border:1.5px solid var(--color-gray-200);border-radius:var(--border-radius-full);font-size:.9rem;outline:none">
        <button type="submit" style="padding:10px 16px;background:var(--color-accent);color:white;border-radius:var(--border-radius-full);border:none;font-size:.9rem;cursor:pointer">Go</button>
      </div>
    </form>
    <a href="/"        class="nav-link">🏠 Home</a>
    <a href="/products" class="nav-link">🛍 Products</a>
    <a href="/cart"    class="nav-link">🛒 Cart</a>
    <% if (currentUser) { %>
      <% if (currentUser.role === 'admin') { %>
        <a href="/admin" class="nav-link">⚙ Admin Dashboard</a>
      <% } %>
      <a href="/logout" class="nav-link" style="color:var(--color-accent)">↩ Logout</a>
    <% } else { %>
      <a href="/login"    class="nav-link">Login</a>
      <a href="/register" class="nav-link btn-primary-nav" style="margin-top:8px;justify-content:center">Register</a>
    <% } %>
  </div>
</div>

<%- include('./flash') %>

<script src="/js/main.js"></script>
