<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products — ShopZone</title>
</head>
<body>

<%- include('./partials/navbar') %>

<div class="page-wrap">

  <!-- Page Hero -->
  <div class="page-hero">
    <div class="container">
      <div class="breadcrumb" style="margin-bottom:10px">
        <a href="/">Home</a>
        <span class="breadcrumb-sep">/</span>
        <span>Products</span>
        <% if (category) { %>
          <span class="breadcrumb-sep">/</span>
          <span><%= category %></span>
        <% } %>
      </div>
      <h1 class="page-hero-title">
        <% if (category) { %><%= category %>
        <% } else if (search) { %>Results for "<%= search %>"
        <% } else { %>All Products<% } %>
      </h1>
      <p style="color:var(--color-gray-500);margin-top:6px;font-size:.9rem">
        <%= totalProducts %> product<%= totalProducts !== 1 ? 's' : '' %> found
      </p>
    </div>
  </div>

  <div class="container section-sm">

    <!-- ── Filter Bar ──────────────────────────────────────── -->
    <form action="/products" method="GET" id="filterForm">
      <div class="filter-bar">
        <div class="filter-bar-group">

          <span class="filter-label">Category</span>
          <select name="category" class="filter-select" onchange="document.getElementById('filterForm').submit()">
            <option value="">All Categories</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>

          <span class="filter-label">Sort</span>
          <select name="sort" class="filter-select" onchange="document.getElementById('filterForm').submit()">
            <option value=""         <%= sort===''           ? 'selected':'' %>>Newest First</option>
            <option value="price_asc"  <%= sort==='price_asc'  ? 'selected':'' %>>Price: Low → High</option>
            <option value="price_desc" <%= sort==='price_desc' ? 'selected':'' %>>Price: High → Low</option>
            <option value="rating_desc"<%= sort==='rating_desc'? 'selected':'' %>>Top Rated</option>
          </select>

          <span class="filter-label">Price</span>
          <input type="number" name="minPrice" placeholder="Min" class="filter-input"
                 value="<%= minPrice %>" min="0">
          <span style="color:var(--color-gray-400)">–</span>
          <input type="number" name="maxPrice" placeholder="Max" class="filter-input"
                 value="<%= maxPrice %>" min="0">

          <!-- preserve search -->
          <% if (search) { %><input type="hidden" name="search" value="<%= search %>"><% } %>

          <button type="submit" class="btn btn-primary btn-sm">Apply</button>

          <% if (search || category || minPrice || maxPrice || sort) { %>
            <a href="/products" class="btn btn-light btn-sm">✕ Clear</a>
          <% } %>
        </div>

        <div class="results-info">
          <strong><%= totalProducts %></strong> products
        </div>
      </div>
    </form>

    <!-- ── Active filter chips ─────────────────────────────── -->
    <% if (search || category || minPrice || maxPrice) { %>
    <div class="active-filters" style="margin-bottom:20px">
      <% if (search) { %>
        <span class="filter-chip">Search: "<%= search %>"
          <a href="/products?<%= category?'category='+encodeURIComponent(category)+'&':'' %><%= sort?'sort='+sort:'' %>"><button>✕</button></a>
        </span>
      <% } %>
      <% if (category) { %>
        <span class="filter-chip">📁 <%= category %>
          <a href="/products?<%= search?'search='+encodeURIComponent(search)+'&':'' %><%= sort?'sort='+sort:'' %>"><button>✕</button></a>
        </span>
      <% } %>
      <% if (minPrice) { %><span class="filter-chip">Min: PKR <%= Number(minPrice).toLocaleString() %></span><% } %>
      <% if (maxPrice) { %><span class="filter-chip">Max: PKR <%= Number(maxPrice).toLocaleString() %></span><% } %>
    </div>
    <% } %>

    <!-- ── Category quick-links ────────────────────────────── -->
    <% if (!category && !search) { %>
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:28px">
      <% [
        {name:'Electronics',emoji:'💻'},
        {name:'Clothing',emoji:'👗'},
        {name:'Books',emoji:'📚'},
        {name:'Home & Kitchen',emoji:'🏠'},
        {name:'Sports',emoji:'⚽'},
        {name:'Beauty',emoji:'💄'},
        {name:'Toys',emoji:'🧸'},
        {name:'Automotive',emoji:'🚗'}
      ].forEach(c => { %>
        <a href="/products?category=<%= encodeURIComponent(c.name) %>"
           style="display:inline-flex;align-items:center;gap:6px;padding:7px 16px;background:var(--color-gray-100);border-radius:var(--border-radius-full);font-size:.82rem;font-weight:600;color:var(--color-gray-700);text-decoration:none;transition:all .2s">
          <%= c.emoji %> <%= c.name %>
        </a>
      <% }) %>
    </div>
    <% } %>

    <!-- ── Product Grid ────────────────────────────────────── -->
    <div class="product-grid">
      <% if (products && products.length > 0) { %>
        <% products.forEach((p, idx) => {
             const hasDiscount = p.isOnSale && p.discountPercent > 0;
             const salePrice   = hasDiscount ? Math.round(p.price*(1-p.discountPercent/100)) : p.price;
             const stars       = '★'.repeat(Math.round(p.rating||4)) + '☆'.repeat(5-Math.round(p.rating||4));
             const stockClass  = p.stock===0 ? 'stock-out' : p.stock<5 ? 'stock-low' : 'stock-in';
             const stockText   = p.stock===0 ? 'Out of Stock' : p.stock<5 ? `Only ${p.stock} left` : 'In Stock';
        %>
        <div class="product-card animate-fade-in-up stagger-<%= (idx%8)+1 %>">
          <div class="product-card-image">
            <% if (p.image) { %>
              <img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy">
            <% } else { %>
              <div class="product-card-image-placeholder">
                <span class="icon"><%
                  const iconMap={Electronics:'💻',Clothing:'👗',Books:'📚','Home & Kitchen':'🏠',Sports:'⚽',Beauty:'💄',Toys:'🧸',Automotive:'🚗'};
                  %><%= iconMap[p.category]||'📦' %></span>
                <span><%= p.category %></span>
              </div>
            <% } %>

            <div class="card-badges">
              <% if (p.featured)  { %><span class="badge badge-featured">⭐ Featured</span><% } %>
              <% if (hasDiscount) { %><span class="badge badge-sale">-<%= p.discountPercent %>%</span><% } %>
              <% if (p.stock===0) { %><span class="badge badge-out-of-stock">Sold Out</span><% } %>
            </div>

            <div class="card-actions-overlay">
              <a href="/products/<%= p._id %>" class="card-quick-btn">👁 View</a>
              <% if (p.stock > 0) { %>
              <button class="card-quick-btn primary"
                data-add-to-cart
                data-id="<%= p._id %>"
                data-name="<%= p.name %>"
                data-price="<%= salePrice %>"
                data-image="<%= p.image||'' %>"
                data-brand="<%= p.brand||'' %>"
                data-category="<%= p.category %>">
                🛒 Add
              </button>
              <% } %>
            </div>
          </div>

          <div class="product-card-body">
            <span class="product-card-category"><%= p.category %></span>
            <a href="/products/<%= p._id %>" style="text-decoration:none">
              <div class="product-card-name"><%= p.name %></div>
            </a>
            <% if (p.brand) { %><div class="product-card-brand"><%= p.brand %></div><% } %>
            <div class="product-card-rating">
              <span class="stars"><%= stars %></span>
              <span class="stars-count">(<%= p.rating||4 %>)</span>
            </div>
            <div class="product-card-price">
              <span class="price-current">PKR <%= salePrice.toLocaleString() %></span>
              <% if (hasDiscount) { %>
                <span class="price-original">PKR <%= p.price.toLocaleString() %></span>
                <span class="price-discount">-<%= p.discountPercent %>%</span>
              <% } %>
            </div>
            <div class="stock-indicator <%= stockClass %>" style="font-size:.78rem;font-weight:500">
              ● <%= stockText %>
            </div>
          </div>
        </div>
        <% }) %>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">🔍</div>
          <div class="empty-state-title">No Products Found</div>
          <div class="empty-state-text">
            Try adjusting your filters or search terms.
          </div>
          <a href="/products" class="btn btn-primary">View All Products</a>
        </div>
      <% } %>
    </div>

    <!-- ── Pagination ──────────────────────────────────────── -->
    <% if (totalPages > 1) { %>
    <div class="pagination">
      <% const qParams = (p) => {
           let q = '?page=' + p;
           if (search)   q += '&search='   + encodeURIComponent(search);
           if (category) q += '&category=' + encodeURIComponent(category);
           if (sort)     q += '&sort='     + sort;
           if (minPrice) q += '&minPrice=' + minPrice;
           if (maxPrice) q += '&maxPrice=' + maxPrice;
           return q;
         };
      %>
      <a href="/products<%= qParams(Math.max(1,currentPage-1)) %>"
         class="page-btn <%= currentPage===1?'disabled':'' %>">← Prev</a>

      <% for (let i=1; i<=totalPages; i++) {
           if (i===1 || i===totalPages || (i>=currentPage-2 && i<=currentPage+2)) { %>
        <a href="/products<%= qParams(i) %>"
           class="page-btn <%= i===currentPage?'active':'' %>"><%= i %></a>
        <% } else if (i===currentPage-3 || i===currentPage+3) { %>
          <span class="page-btn" style="pointer-events:none;border:none">…</span>
        <% } %>
      <% } %>

      <a href="/products<%= qParams(Math.min(totalPages,currentPage+1)) %>"
         class="page-btn <%= currentPage===totalPages?'disabled':'' %>">Next →</a>
    </div>
    <% } %>

  </div><!-- /container -->
</div><!-- /page-wrap -->

<%- include('./partials/footer') %>
<button class="scroll-top" aria-label="Back to top">↑</button>
<script src="/js/cart.js"></script>
</body>
</html>
