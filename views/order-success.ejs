<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Placed — ShopZone</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('./partials/navbar') %>
<div class="page-wrap">
  <div class="container" style="min-height:70vh;display:flex;align-items:center;justify-content:center">
    <div style="text-align:center;max-width:480px;padding:48px 32px">
      <div style="font-size:5rem;margin-bottom:24px;animation:scale-in .5s cubic-bezier(.34,1.56,.64,1)">🎉</div>
      <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:700;margin-bottom:12px;color:var(--color-gray-900)">
        Order Placed Successfully!
      </h1>
      <p style="color:var(--color-gray-500);margin-bottom:8px">
        Thank you for shopping with ShopZone. Your order has been received.
      </p>
      <% if (orderId) { %>
        <p style="font-size:.875rem;color:var(--color-gray-400);margin-bottom:32px">
          Order ID: <strong style="font-family:monospace;color:var(--color-gray-700)">#<%= orderId.toString().slice(-8).toUpperCase() %></strong>
        </p>
      <% } %>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a href="/products" class="btn btn-primary">Continue Shopping</a>
        <a href="/" class="btn btn-light">Back to Home</a>
      </div>
    </div>
  </div>
</div>
<%- include('./partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
